# Local Docker Compose configuration for SurfaceLab.
# Copy to `.env` at the repo root before running Compose with `--env-file .env`.

FRONTEND_PORT=3000

POSTGRES_DB=surfacelab
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres
POSTGRES_MIGRATE_PASSWORD=change-me-migrate
POSTGRES_SCANNER_PASSWORD=change-me-scanner
POSTGRES_ORCHESTRATOR_PASSWORD=change-me-orchestrator

ORCHESTRATOR_API_KEY=dev-orchestrator-api-key
ORCHESTRATOR_REQUEST_TIMEOUT_MS=10000
ORCHESTRATOR_REQUIRE_API_KEY=true
ORCHESTRATOR_RATE_LIMIT_ENABLED=true
ORCHESTRATOR_RATE_LIMIT_RPM=60
ORCHESTRATOR_RATE_LIMIT_BURST=20
ORCHESTRATOR_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ORCHESTRATOR_TRUSTED_HOSTS=localhost,127.0.0.1,[::1],frontend,orchestrator
ORCHESTRATOR_SECURITY_HEADERS_ENABLED=true
ORCHESTRATOR_BODY_LIMIT_BYTES=1048576
ORCHESTRATOR_WORKERS=2

SCANNER_APP_ENV=development
SCANNER_SERVICE_TOKEN=dev-scanner-token
SCANNER_GRPC_AUTH_MODE=bearer
SCANNER_GRPC_TLS_ENABLED=false
SCANNER_GRPC_TLS_CA_FILE=/certificates/scanner-ca.crt
SCANNER_GRPC_TLS_CERT_FILE=/certificates/scanner.crt
SCANNER_GRPC_TLS_KEY_FILE=/certificates/scanner.key
SCANNER_GRPC_TLS_SERVER_NAME=
SCANNER_RATE_LIMIT_RPS=5
SCANNER_RATE_LIMIT_BURST=10
SCANNER_MAX_CONCURRENT_REQUESTS=4
SCANNER_REQUEST_TIMEOUT_SECONDS=30

REDIS_ENABLED=true
NVD_CACHE_TTL_SECONDS=86400

# Optional external integrations
NVD_API_KEY=
NVD_ENABLED=false
NVD_MIN_INTERVAL_SECONDS=6
NVD_TIMEOUT_SECONDS=10
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3
OLLAMA_TIMEOUT_SECONDS=30
