DATABASE_URL=postgresql://surfacelab_orchestrator:change-me-orchestrator@localhost:5432/surfacelab?sslmode=disable

# Scanner gRPC service configuration
SCANNER_GRPC_ADDRESS=localhost:50051
SCANNER_SERVICE_TOKEN=dev-scanner-token
SCANNER_GRPC_AUTH_MODE=bearer

# TLS configuration for gRPC communication with the Scanner service
SCANNER_GRPC_TLS_ENABLED=false
SCANNER_GRPC_TLS_CA_FILE=../../certificate/scanner-ca.crt
SCANNER_GRPC_TLS_SERVER_NAME=

# Optional: NVD configuration
NVD_API_KEY=your-nvd-api-key
NVD_ENABLED=true
NVD_MIN_INTERVAL_SECONDS=6
NVD_TIMEOUT_SECONDS=10

# Optional: Redis configuration
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
NVD_CACHE_TTL_SECONDS=86400

# Optional: Ollama configuration
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
OLLAMA_TIMEOUT_SECONDS=30
