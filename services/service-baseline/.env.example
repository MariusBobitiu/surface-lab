# Environment variables for the reusable service baseline

APP_ENV=development
GRPC_PORT=50061

SERVICE_TOKEN=dev-service-baseline-token

RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
MAX_CONCURRENT_REQUESTS=4
REQUEST_TIMEOUT_SECONDS=30

GRPC_TLS_ENABLED=false
GRPC_TLS_CERT_FILE=../../scanner.crt
GRPC_TLS_KEY_FILE=../../scanner.key
