# Environment variables for the Scanner service

# Database connection string (replace with actual credentials and database name)
DATABASE_URL=postgresql://surfacelab_scanner:change-me-scanner@localhost:5432/surfacelab?sslmode=disable

# General application settings
APP_ENV=development
GRPC_PORT=50051

# TLS settings for gRPC (set to true if using TLS, and provide the necessary certificate files)
SCANNER_GRPC_TLS_ENABLED=false
SCANNER_GRPC_TLS_CERT_FILE=../certificate/scanner.crt
SCANNER_GRPC_TLS_KEY_FILE=../certificate/scanner.key
SCANNER_GRPC_TLS_CA_FILE=../certificate/scanner-ca.crt

# Scanner service specific environment variables
SCANNER_SERVICE_TOKEN=dev-scanner-token
SCANNER_RATE_LIMIT_RPS=5
SCANNER_RATE_LIMIT_BURST=10
SCANNER_MAX_CONCURRENT_REQUESTS=4
SCANNER_REQUEST_TIMEOUT_SECONDS=30
